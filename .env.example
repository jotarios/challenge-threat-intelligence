# OpenSearch connection
OPENSEARCH_URL=http://localhost:9200

# PostgreSQL connection (used by app via SQLAlchemy async, and by Alembic/seed via sync)
POSTGRES_DSN=postgresql://postgres:postgres@localhost:5433/postgres

# Redis connection
REDIS_URL=redis://localhost:6379

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Dashboard pre-computation refresh interval in seconds
DASHBOARD_REFRESH_INTERVAL=120
