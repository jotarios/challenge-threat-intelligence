# OpenSearch connection
OPENSEARCH_URL=http://localhost:9200

# PostgreSQL connection — primary (write) engine
POSTGRES_DSN=postgresql://postgres:postgres@localhost:5433/postgres

# PostgreSQL connection — read-only engine (Redshift in production, same PG locally)
POSTGRES_READ_DSN=postgresql://postgres:postgres@localhost:5433/postgres

# Redis connection
REDIS_URL=redis://localhost:6379

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Dashboard pre-computation refresh interval in seconds
DASHBOARD_REFRESH_INTERVAL=120

# Timeline pre-computation refresh interval in seconds
TIMELINE_REFRESH_INTERVAL=120

# Rate limiting (token bucket)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_CAPACITY=100
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_EXEMPT_PATHS=/docs,/openapi.json
RATE_LIMIT_TRUSTED_PROXIES=
